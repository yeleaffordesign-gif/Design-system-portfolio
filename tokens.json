{
  "$description": "Cherry Ye · Design Tokens. W3C Design Tokens (DTCG) 格式，可导入 Style Dictionary / Tokens Studio。与 tokens.css 保持同源。",
  "color": {
    "text": {
      "primary":   { "$type": "color", "$value": "#1a1a1a", "$description": "正文主色 · 标题" },
      "secondary": { "$type": "color", "$value": "#5a5a55", "$description": "次级正文 · 说明" },
      "tertiary":  { "$type": "color", "$value": "#8e8e87", "$description": "弱化文字 · 元信息" }
    },
    "bg": {
      "primary":  { "$type": "color", "$value": "#fafaf7", "$description": "全站米白底" },
      "elevated": { "$type": "color", "$value": "#ffffff", "$description": "卡片 · 浮层" }
    },
    "border": {
      "default": { "$type": "color", "$value": "rgba(26,26,26,0.08)" },
      "strong":  { "$type": "color", "$value": "rgba(26,26,26,0.16)" }
    },
    "fill": {
      "subtle": { "$type": "color", "$value": "rgba(26,26,26,0.02)" },
      "default":{ "$type": "color", "$value": "rgba(26,26,26,0.04)" }
    },
    "accent": {
      "default":     { "$type": "color", "$value": "#2d5a3d", "$description": "品牌绿 · 链接 · 标记" },
      "surface":     { "$type": "color", "$value": "rgba(33,92,51,0.08)", "$description": "着色面。待对账：色相与 accent.default 略有漂移" },
      "line":        { "$type": "color", "$value": "rgba(33,92,51,0.25)" },
      "line-strong": { "$type": "color", "$value": "rgba(33,92,51,0.5)" }
    }
  },
  "fontFamily": {
    "serif": { "$type": "fontFamily", "$value": ["Fraunces", "Noto Serif SC", "Georgia", "serif"], "$description": "标题 · 展示" },
    "sans":  { "$type": "fontFamily", "$value": ["Inter", "Noto Serif SC", "-apple-system", "sans-serif"], "$description": "正文 · 界面" }
  },
  "fontSize": {
    "caption":  { "$type": "dimension", "$value": "11px" },
    "small":    { "$type": "dimension", "$value": "12px" },
    "meta":     { "$type": "dimension", "$value": "13px" },
    "body-sm":  { "$type": "dimension", "$value": "14px" },
    "body":     { "$type": "dimension", "$value": "15px" },
    "body-lg":  { "$type": "dimension", "$value": "17px" },
    "lead":     { "$type": "dimension", "$value": "clamp(17px, 1.4vw, 21px)" },
    "h4":       { "$type": "dimension", "$value": "20px" },
    "h3":       { "$type": "dimension", "$value": "clamp(20px, 2.4vw, 24px)" },
    "h2":       { "$type": "dimension", "$value": "clamp(28px, 3.5vw, 40px)" },
    "h1":       { "$type": "dimension", "$value": "clamp(34px, 5.5vw, 56px)" },
    "display":  { "$type": "dimension", "$value": "clamp(44px, 7.5vw, 84px)" }
  },
  "fontWeight": {
    "light":   { "$type": "fontWeight", "$value": 300 },
    "regular": { "$type": "fontWeight", "$value": 400 },
    "medium":  { "$type": "fontWeight", "$value": 500 }
  },
  "lineHeight": {
    "tight":   { "$type": "number", "$value": 1.15 },
    "snug":    { "$type": "number", "$value": 1.35 },
    "normal":  { "$type": "number", "$value": 1.5 },
    "body":    { "$type": "number", "$value": 1.7 },
    "relaxed": { "$type": "number", "$value": 1.85 }
  },
  "letterSpacing": {
    "tight":  { "$type": "dimension", "$value": "-0.02em" },
    "snug":   { "$type": "dimension", "$value": "-0.005em" },
    "normal": { "$type": "dimension", "$value": "0" },
    "wide":   { "$type": "dimension", "$value": "0.04em" },
    "wider":  { "$type": "dimension", "$value": "0.08em" },
    "widest": { "$type": "dimension", "$value": "0.12em" }
  },
  "radius": {
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "6px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "18px" },
    "pill": { "$type": "dimension", "$value": "100px" }
  },
  "duration": {
    "fast":   { "$type": "duration", "$value": "150ms" },
    "default":{ "$type": "duration", "$value": "250ms" },
    "slow":   { "$type": "duration", "$value": "300ms" },
    "reveal": { "$type": "duration", "$value": "800ms" }
  },
  "layout": {
    "container": { "$type": "dimension", "$value": "880px" },
    "gutter":    { "$type": "dimension", "$value": "clamp(24px, 5vw, 48px)" }
  },
  "spacing": {
    "$description": "建议基线（8px 节奏），style.css 尚未消费。",
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" },
    "9": { "$type": "dimension", "$value": "96px" }
  }
}
